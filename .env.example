# Anthropic-compatible model endpoint
ANTHROPIC_API_KEY="your_api_key"
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_MODEL="claude-3-5-sonnet-20241022"
ANTHROPIC_VERSION="2023-06-01"
# Optional: set bearer when your relay expects Authorization: Bearer <token>
ANTHROPIC_AUTH_MODE="x-api-key"

# Optional search verification via Tavily REST API
TAVILY_API_KEY=""
TAVILY_API_URL="https://api.tavily.com/search"

# Local crawler / storage
# Optional: if omitted, the app will first look for .runtime\\crawl4ai\\.venv inside the repo.
CRAWL4AI_ROOT="F:\\Projects\\crawl4ai-local"
CRAWL4AI_PYTHON=""
FIRECRAWL_BASE_URL="https://api.firecrawl.dev"
FIRECRAWL_API_KEY=""
PYTHON_PATH=""
PYTHON_BOOTSTRAP="python"
TRENDRADAR_ROOT="F:\\Projects\\媒体信息投放\\TrendRadar"
CV_CAT_ROOT="F:\\Projects\\媒体信息投放\\cv-cat"
WECHAT_SPIDER_ROOT="F:\\Projects\\公众号文章爬虫\\wechat_spider\\wechat_spider"
WECHAT_CACHE_FILE="F:\\Projects\\公众号文章爬虫\\wechat_spider\\wechat_spider\\wechat_cache.json"
# Optional fallback for mp.weixin.qq.com article access. Prefer filling this from Settings -> wechat_spider.
WECHAT_COOKIE=""
EMBEDDING_MODEL="Xenova/paraphrase-multilingual-MiniLM-L12-v2"
EMBEDDING_DTYPE="q8"
RERANKER_MODEL="Xenova/bge-reranker-base"
RERANKER_DTYPE="q8"
EMBEDDING_TIMEOUT_MS="8000"
KNOWLEDGE_DB_PATH="F:\\Projects\\dehydrated-reader\\dehydrated-reader\\data\\knowledge-base.sqlite"
KNOWLEDGE_BASE_PATH="F:\\Projects\\dehydrated-reader\\dehydrated-reader\\data\\knowledge-base.jsonl"
