{
  "name": "dehydrated-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --port=4300 --host=0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "mcp:knowledge": "tsx server/knowledge_mcp.ts",
    "start:frontend": "powershell -ExecutionPolicy Bypass -File scripts/start-frontend.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "setup:crawl4ai": "powershell -ExecutionPolicy Bypass -File scripts/setup-crawl4ai.ps1",
    "setup:social-bridge": "powershell -ExecutionPolicy Bypass -File scripts/setup-social-bridge.ps1",
    "setup:auth-assistant": "powershell -ExecutionPolicy Bypass -File scripts/setup-auth-assistant.ps1",
    "setup:yt-dlp": "powershell -ExecutionPolicy Bypass -File scripts/setup-yt-dlp.ps1",
    "setup:whisper": "powershell -ExecutionPolicy Bypass -File scripts/setup-whisper.ps1",
    "setup:whisper:model": "powershell -ExecutionPolicy Bypass -Command \"$env:WHISPER_PREWARM='1'; & scripts/setup-whisper.ps1\"",
    "setup:whisper:small:mirror": "powershell -ExecutionPolicy Bypass -File scripts/download-whisper-small.ps1",
    "setup:models": "tsx scripts/prewarm-models.ts",
    "setup": "npm run setup:models && npm run setup:crawl4ai && npm run setup:social-bridge && npm run setup:auth-assistant && npm run setup:yt-dlp && npm run setup:whisper"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@huggingface/transformers": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsdom": "^29.0.2",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.14.0",
    "motion": "^12.23.24",
    "playwright": "^1.54.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "undici": "^8.1.0",
    "vite": "^6.2.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
